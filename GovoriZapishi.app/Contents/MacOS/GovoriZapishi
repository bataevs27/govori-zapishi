#!/usr/bin/arch -arm64 /bin/bash
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$PATH"

BREW="/opt/homebrew/bin/brew"
APP_BUNDLE="$(dirname "$(dirname "$(dirname "$0")")")"
RESOURCES="$APP_BUNDLE/Contents/Resources"
GZ_DIR="$HOME/govori-zapishi"
VENV_DIR="$GZ_DIR/venv"
LOG="/tmp/gz.log"
PROGRESS="/tmp/gz_install_progress"

echo "=== $(date) ===" >> "$LOG"

notify() {
    osascript -e "display notification \"$2\" with title \"Govori-Zapishi\" subtitle \"$1\"" 2>/dev/null
}

# ── Скрипты из бандла ─────────────────────────────────────────────────────────
mkdir -p "$GZ_DIR"
cp "$RESOURCES/menubar.py"       "$GZ_DIR/menubar.py"
cp "$RESOURCES/settings_window.py" "$GZ_DIR/settings_window.py"
cp "$RESOURCES/installer_ui.py"  "$GZ_DIR/installer_ui.py"

# ── Homebrew ──────────────────────────────────────────────────────────────────
if ! [ -x "$BREW" ]; then
    osascript -e 'tell application "Terminal"
        activate
        do script "/bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
        display dialog "Homebrew устанавливается в Terminal." & return & return & "После завершения:" & return & "1. Выполните команды из раздела Next steps" & return & "2. Перезапустите Govori-Zapishi" buttons {"OK"} default button "OK" with title "Govori-Zapishi"
    end tell' 2>/dev/null
    exit 0
fi

# ── Поиск Python 3.11+ (любая версия) ────────────────────────────────────────
find_python() {
    python3 -c \
        "import sys; print(sys.executable) if sys.version_info >= (3,11) else exit(1)" \
        2>/dev/null || true
}
PYTHON=$(find_python)

# ── Brew-зависимости (тихо, без UI) ──────────────────────────────────────────
NEEDS_BREW=false
[ -z "$PYTHON" ]                                                            && NEEDS_BREW=true
command -v ffmpeg &>/dev/null                                               || NEEDS_BREW=true
[ -n "$PYTHON" ] && ! "$PYTHON" -c "import tkinter" 2>/dev/null            && NEEDS_BREW=true
system_profiler SPAudioDataType 2>/dev/null | grep -qi "BlackHole" \
    || [ -d "/Library/Audio/Plug-Ins/HAL/BlackHole2ch.driver" ]            || NEEDS_BREW=true

if [ "$NEEDS_BREW" = true ]; then
    # Python (если нет — устанавливаем тихо, UI запустим после)
    if [ -z "$PYTHON" ]; then
        "$BREW" install python@3.11 python-tk@3.11 >> "$LOG" 2>&1
        PYTHON=$(find_python)
        if [ -z "$PYTHON" ]; then
            notify "Ошибка" "Не удалось установить Python. См. /tmp/gz.log"
            exit 1
        fi
    fi

    # tkinter — ставим совпадающий пакет для найденного Python
    if ! "$PYTHON" -c "import tkinter" 2>/dev/null; then
        PY_VER=$("$PYTHON" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
        "$BREW" install "python-tk@$PY_VER" >> "$LOG" 2>&1
        if ! "$PYTHON" -c "import tkinter" 2>/dev/null; then
            "$BREW" install python@3.11 python-tk@3.11 >> "$LOG" 2>&1
            PYTHON="/opt/homebrew/bin/python3.11"
        fi
    fi

    # ffmpeg и BlackHole — тихо
    command -v ffmpeg &>/dev/null || "$BREW" install ffmpeg >> "$LOG" 2>&1
    { system_profiler SPAudioDataType 2>/dev/null | grep -qi "BlackHole" \
        || [ -d "/Library/Audio/Plug-Ins/HAL/BlackHole2ch.driver" ]; } \
        || "$BREW" install --cask blackhole-2ch >> "$LOG" 2>&1
fi

# ── Python-пакеты ─────────────────────────────────────────────────────────────
if ! "$VENV_DIR/bin/python3" -c "import rumps, mlx_whisper, pyannote.audio, requests, AppKit" 2>/dev/null; then
    # Запускаем окно прогресса
    rm -f "$PROGRESS"
    "$PYTHON" "$GZ_DIR/installer_ui.py" &
    UI_PID=$!

    # Устанавливаем пакеты по одному — обновляем прогресс
    PACKAGES=(sounddevice soundfile numpy rumps requests mlx-whisper "pyannote.audio")
    TOTAL=${#PACKAGES[@]}

    "$PYTHON" -m venv --clear "$VENV_DIR" >> "$LOG" 2>&1

    for i in "${!PACKAGES[@]}"; do
        pkg="${PACKAGES[$i]}"
        echo "$pkg|$((i + 1))|$TOTAL" > "$PROGRESS"
        "$VENV_DIR/bin/pip" install --quiet "$pkg" >> "$LOG" 2>&1
    done

    echo "done" > "$PROGRESS"
    wait "$UI_PID" 2>/dev/null

    if ! "$VENV_DIR/bin/python3" -c "import rumps, mlx_whisper, pyannote.audio, requests" 2>/dev/null; then
        notify "Ошибка" "Не удалось установить пакеты. См. /tmp/gz.log"
        exit 1
    fi
fi

# ── Запуск ────────────────────────────────────────────────────────────────────
"$VENV_DIR/bin/python3" "$GZ_DIR/menubar.py" >> "$LOG" 2>&1
